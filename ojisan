<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>おじさん構文ジェネレーターPro</title>
    <style>
        :root { --ojisan-pink: #ffafcc; --ojisan-blue: #a2d2ff; }
        body { font-family: "MS PGothic", "ヒラギノ角ゴ ProW3", sans-serif; background-color: var(--ojisan-blue); display: flex; justify-content: center; padding: 20px; }
        .card { background: white; border: 5px solid var(--ojisan-pink); border-radius: 15px; padding: 20px; max-width: 450px; width: 100%; box-shadow: 10px 10px 0px rgba(0,0,0,0.1); }
        h1 { color: #d63384; font-size: 24px; text-shadow: 1px 1px 0 #fff; margin-bottom: 5px; }
        .sub { font-size: 12px; color: #666; margin-bottom: 20px; }
        textarea { width: 95%; height: 80px; border: 2px solid #ddd; border-radius: 10px; padding: 10px; font-size: 16px; margin-bottom: 10px; }
        .btns { display: grid; gap: 10px; }
        .main-btn { background: #ff4757; color: white; border: none; padding: 15px; border-radius: 50px; font-weight: bold; cursor: pointer; font-size: 18px; box-shadow: 0 4px 0 #b33939; }
        .main-btn:active { transform: translateY(4px); box-shadow: none; }
        #result-area { margin-top: 20px; background: #fffde7; border: 2px dashed #f1c40f; padding: 15px; border-radius: 10px; min-height: 100px; position: relative; line-height: 1.6; color: #333; }
        .copy-btn { background: #2f3542; color: white; border: none; padding: 8px; border-radius: 5px; cursor: pointer; font-size: 12px; margin-top: 10px; }
    </style>
</head>
<body>

<div class="card">
    <h1>🕺 おじさん構文Maker 🕺</h1>
    <p class="sub">気になるあの子に送っちゃおうカナ❓💦</p>
    
    <textarea id="input" placeholder="例：お疲れ様です。明日空いていますか？"></textarea>
    
    <div class="btns">
        <button class="main-btn" onclick="transform()">変換しちゃうゾ〜🎵</button>
    </div>

    <div id="result-area">
        <div id="output">（ここに結果が出るヨ✨）</div>
        <button class="copy-btn" onclick="copyText()">結果をコピーする❗️</button>
    </div>
    
    <p style="margin-top:20px; font-size:10px; color:#999;">【PR】おじさんスタンプ発売中！</p>
</div>

<script>
    const ojisanData = {
        emojis: ["❓", "❗", "💦", "✨", "🎵", "😴", "😘", "☀️", "🏃‍♂️", "🍷", "🍴", "💖"],
        words: ["チャン", "くん", "お嬢さん"],
        endings: ["だヨ(^o^)", "カナ❓", "ちゃおうカナ❗️", "だネ✨", "（笑）", "💦", "かな？（￣ー￣）", "だぞっ😘"],
        greetings: ["お疲れ様✨", "ヤッホー！", "元気カナ❓", "コンニチハ✨"]
    };

    function transform() {
        let input = document.getElementById('input').value;
        if (!input) { alert("何か書いてくれないと寂しいナ…💦"); return; }

        let target = ojisanData.words[Math.floor(Math.random() * ojisanData.words.length)];
        let greet = ojisanData.greetings[Math.floor(Math.random() * ojisanData.greetings.length)];
        
        // 変換処理
        let text = input
            .replace(/！/g, "❗")
            .replace(/？/g, "❓")
            .replace(/。/g, () => ojisanData.endings[Math.floor(Math.random() * ojisanData.endings.length)])
            .replace(/ね/g, "ネ✨");

        // ランダムにカタカナ化
        text = text.split('').map(char => (Math.random() > 0.8 && char.match(/[ぁ-ん]/)) ? toKatakana(char) : char).join('');

        // 絵文字まみれにする
        let final = `〇〇${target}、${greet}\n${text}`;
        let withEmoji = "";
        final.split("").forEach(c => {
            withEmoji += c;
            if(Math.random() > 0.7) withEmoji += ojisanData.emojis[Math.floor(Math.random() * ojisanData.emojis.length)];
        });

        document.getElementById('output').innerText = withEmoji;
    }

    function toKatakana(src) {
        return src.replace(/[ぁ-ん]/g, s => String.fromCharCode(s.charCodeAt(0) + 96));
    }

    function copyText() {
        const text = document.getElementById('output').innerText;
        navigator.clipboard.writeText(text);
        alert("コピーしたヨ❗早く送ってネ✨");
    }
</script>

</body>
</html>
